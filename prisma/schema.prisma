generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Inventory {
  id                 Int              @id @default(autoincrement())
  variant_id         Int
  available_quantity Int
  reversed_quantity  Int
  update_at          DateTime         @default(now()) @db.DateTime(0)
  product_variants   product_variants @relation(fields: [variant_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_Inventory_product_variants")

  @@index([variant_id], map: "FK_Inventory_product_variants")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model InventoryTransaction {
  id               Int
  variant_id       Int
  change_quantity  Int
  reference_id     Int
  created_at       DateTime         @default(now()) @db.DateTime(0)
  product_variants product_variants @relation(fields: [variant_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_InventoryTransaction_product_variants")

  @@index([variant_id], map: "FK_InventoryTransaction_product_variants")
  @@ignore
}

model EFMigrationsHistory {
  MigrationId    String @id @db.VarChar(150)
  ProductVersion String @db.VarChar(32)

  @@map("__EFMigrationsHistory")
}

model attribute_value {
  id                Int                 @id @default(autoincrement())
  attribute_id      Int
  value             String              @db.Char(50)
  attributes        attributes          @relation(fields: [attribute_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_attribute_value_attributes")
  variant_attribute variant_attribute[]

  @@index([attribute_id], map: "FK_attribute_value_attributes")
}

model attributes {
  id                  Int                   @id @default(autoincrement())
  name                String                @db.VarChar(255)
  slug                String?               @db.VarChar(255)
  data_type           String                @db.VarChar(50)
  unit                String                @db.VarChar(50)
  status              Int                   @default(1)
  attribute_value     attribute_value[]
  category_attributes category_attributes[]
  product_attribute   product_attribute[]
  variant_attribute   variant_attribute[]
}

model brands {
  id              Int               @id @default(autoincrement())
  name            String            @db.VarChar(50)
  slug            String            @default("default-slug") @db.VarChar(50)
  status          Int               @default(1)
  category_brands category_brands[]
  products        products[]
}

model cart {
  id               Int              @id @default(autoincrement())
  user_id          Int
  variant_id       Int
  quantity         Int
  unit_price       Decimal?         @db.Decimal(18, 0)
  product_variants product_variants @relation(fields: [variant_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_cart_product_variants")
  users            users            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_cart_users")

  @@index([variant_id], map: "FK_cart_product_variants")
  @@index([user_id], map: "FK_cart_users")
}

model categories {
  id                  Int                   @id @default(autoincrement())
  name                String                @db.VarChar(120)
  slug                String                @unique(map: "UQ_categories_slug") @db.VarChar(140)
  parent_id           Int?
  path                String?               @db.VarChar(400)
  level               Int                   @default(0)
  status              Int                   @default(1)
  created_at          DateTime              @default(dbgenerated("(utc_timestamp(6))")) @db.DateTime(6)
  category_attributes category_attributes[]
  category_brands     category_brands[]
  products            products[]
}

model category_attributes {
  id               Int        @id @default(autoincrement())
  category_id      Int
  attribute_id     Int
  is_filterable    Boolean    @default(false)
  is_variant_level Boolean    @default(false)
  is_required      Boolean    @default(false)
  attributes       attributes @relation(fields: [attribute_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_category_attributes_attributes")
  categories       categories @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_category_attributes_categories")

  @@index([attribute_id], map: "FK_category_attributes_attributes")
  @@index([category_id], map: "FK_category_attributes_categories")
}

model category_brands {
  id          Int        @id @default(autoincrement())
  brand_id    Int
  category_id Int
  brands      brands     @relation(fields: [brand_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_category_brands_brands")
  categories  categories @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_category_brands_categories")

  @@index([brand_id], map: "FK_category_brands_brands")
  @@index([category_id], map: "FK_category_brands_categories")
}

model districts {
  id             Int              @id @default(autoincrement())
  name           String           @db.VarChar(100)
  code           String           @unique(map: "UQ_districts_code") @db.VarChar(20)
  province_id    Int
  status         Int              @default(1)
  provinces      provinces        @relation(fields: [province_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_districts_provinces")
  user_addresses user_addresses[]
  wards          wards[]

  @@index([province_id], map: "IX_districts_province_id")
}

model order_detail {
  id               Int               @id @default(autoincrement())
  order_id         Int
  variant_id       Int?
  quantity         Int
  orders           orders            @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_order_detail_orders")
  product_variants product_variants? @relation(fields: [variant_id], references: [id], onUpdate: NoAction, map: "FK_order_detail_product_variants")

  @@index([order_id], map: "FK_order_detail_orders")
  @@index([variant_id], map: "FK_order_detail_product_variants")
}

model orders {
  id             Int             @id @default(autoincrement())
  user_id        Int
  discount       Decimal         @db.Decimal(18, 0)
  total          Decimal         @db.Decimal(18, 0)
  created_at     DateTime        @default(now()) @db.DateTime(0)
  status         Int             @default(1)
  address_id     Int?
  order_detail   order_detail[]
  user_addresses user_addresses? @relation(fields: [address_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_orders_user_addresses")
  users          users           @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_orders_users")

  @@index([address_id], map: "FK_orders_user_addresses")
  @@index([user_id], map: "FK_orders_users")
}

model product_attribute {
  id                 Int        @id @default(autoincrement())
  product_id         Int
  attribute_id       Int
  value_text         String?    @db.VarChar(50)
  value_decimal      Decimal?   @db.Decimal(18, 0)
  value_int          Int?
  attribute_value_id Int?
  attributes         attributes @relation(fields: [attribute_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_product_attribute_attributes")
  products           products   @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_product_attribute_products")

  @@index([attribute_id], map: "FK_product_attribute_attributes")
  @@index([product_id], map: "FK_product_attribute_products")
}

model product_image {
  id               Int              @id @default(autoincrement())
  product_id       Int
  variant_id       Int
  url              String           @db.VarChar(250)
  product_variants product_variants @relation(fields: [variant_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_product_image_product_variants")

  @@index([variant_id], map: "FK_product_image_product_variants")
}

model product_variants {
  id                   Int                    @id @default(autoincrement())
  name                 String                 @default("default") @db.Char(250)
  product_id           Int
  SKU                  String                 @db.Char(255)
  price                Int
  status               Int                    @default(1)
  quantity             Int                    @default(1)
  created_at           DateTime               @default(now()) @db.DateTime(0)
  Inventory            Inventory[]
  InventoryTransaction InventoryTransaction[] @ignore
  cart                 cart[]
  order_detail         order_detail[]
  product_image        product_image[]
  product_media        product_media[]
  products             products               @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_product_variants_products")
  variant_attribute    variant_attribute[]

  @@index([product_id], map: "FK_product_variants_products")
}

model products {
  id                Int                 @id @default(autoincrement())
  name              String              @db.VarChar(255)
  slug              String              @db.Char(255)
  brand_id          Int?
  category_id       Int
  description       String              @db.Text
  rating            Decimal             @default(0.00) @db.Decimal(3, 2)
  status            Int                 @default(1)
  created_at        DateTime            @default(now()) @db.DateTime(0)
  product_attribute product_attribute[]
  product_content   product_content[]
  product_media     product_media[]
  product_variants  product_variants[]
  brands            brands?             @relation(fields: [brand_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_products_brands")
  categories        categories          @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_products_categories")

  @@index([brand_id], map: "FK_products_brands")
  @@index([category_id], map: "FK_products_categories")
}

model provinces {
  id             Int              @id @default(autoincrement())
  name           String           @db.VarChar(100)
  code           String           @unique(map: "UQ_provinces_code") @db.VarChar(20)
  status         Int              @default(1)
  districts      districts[]
  user_addresses user_addresses[]
}

model user_addresses {
  id             Int       @id @default(autoincrement())
  user_id        Int
  full_name      String    @db.VarChar(100)
  phone          String    @db.VarChar(20)
  province_id    Int
  district_id    Int
  ward_id        Int
  address_detail String    @db.VarChar(500)
  address_type   Int       @default(1)
  is_default     Boolean   @default(false)
  status         Int       @default(1)
  created_at     DateTime  @default(now()) @db.DateTime(0)
  updated_at     DateTime? @db.DateTime(0)
  orders         orders[]
  districts      districts @relation(fields: [district_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_user_addresses_districts")
  provinces      provinces @relation(fields: [province_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_user_addresses_provinces")
  users          users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_user_addresses_users")
  wards          wards     @relation(fields: [ward_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_user_addresses_wards")

  @@index([district_id], map: "FK_user_addresses_districts")
  @@index([province_id], map: "FK_user_addresses_provinces")
  @@index([ward_id], map: "FK_user_addresses_wards")
  @@index([user_id], map: "IX_user_addresses_user_id")
}

model users {
  id               Int                @id @default(autoincrement())
  email            String             @db.Char(50)
  password         String             @db.Char(150)
  phone            String             @db.Char(11)
  full_name        String             @db.VarChar(50)
  role             Int
  is_verified      Int                @default(0)
  status           Int
  created_at       DateTime?          @default(now()) @db.Timestamp(0)
  cart             cart[]
  content_versions content_versions[]
  media_assets     media_assets[]
  orders           orders[]
  user_addresses   user_addresses[]
}

model variant_attribute {
  id                 Int              @id @default(autoincrement())
  attribute_id       Int
  variant_id         Int
  value_int          Int?
  value_decimal      Decimal?         @db.Decimal(18, 0)
  value_text         String?          @db.VarChar(50)
  attribute_value_id Int?
  attribute_value    attribute_value? @relation(fields: [attribute_value_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_variant_attribute_attribute_value")
  attributes         attributes       @relation(fields: [attribute_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_variant_attribute_attributes")
  product_variants   product_variants @relation(fields: [variant_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_variant_attribute_product_variants")

  @@index([attribute_value_id], map: "FK_variant_attribute_attribute_value")
  @@index([attribute_id], map: "FK_variant_attribute_attributes")
  @@index([variant_id], map: "FK_variant_attribute_product_variants")
}

model wards {
  id             Int              @id @default(autoincrement())
  name           String           @db.VarChar(100)
  code           String           @unique(map: "UQ_wards_code") @db.VarChar(20)
  district_id    Int
  status         Int              @default(1)
  user_addresses user_addresses[]
  districts      districts        @relation(fields: [district_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_wards_districts")

  @@index([district_id], map: "IX_wards_district_id")
}

model content_blocks {
  id               Int              @id @default(autoincrement())
  version_id       Int
  block_type       String           @db.VarChar(50)
  sort_order       Int              @default(0) @db.SmallInt
  data             Json
  anchor_id        String?          @db.VarChar(100)
  content_versions content_versions @relation(fields: [version_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_blocks_versions")

  @@index([version_id, sort_order], map: "IDX_blocks_version_order")
}

model content_versions {
  id                                                                     Int               @id @default(autoincrement())
  product_content_id                                                     Int
  version_number                                                         Int               @default(1)
  created_by                                                             Int?
  created_at                                                             DateTime          @default(now()) @db.DateTime(0)
  change_note                                                            String?           @db.VarChar(255)
  content_blocks                                                         content_blocks[]
  product_content_content_versions_product_content_idToproduct_content   product_content   @relation("content_versions_product_content_idToproduct_content", fields: [product_content_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_versions_product_content")
  users                                                                  users?            @relation(fields: [created_by], references: [id], onUpdate: NoAction, map: "FK_versions_users")
  product_content_product_content_draft_version_idTocontent_versions     product_content[] @relation("product_content_draft_version_idTocontent_versions")
  product_content_product_content_published_version_idTocontent_versions product_content[] @relation("product_content_published_version_idTocontent_versions")

  @@index([created_by], map: "FK_versions_users")
  @@index([product_content_id], map: "IDX_versions_content")
}

model media_assets {
  id            Int             @id @default(autoincrement())
  original_name String          @db.VarChar(255)
  storage_key   String          @db.VarChar(500)
  cdn_provider  String?         @default("local") @db.VarChar(50)
  mime_type     String          @db.VarChar(100)
  file_size     Int?            @db.UnsignedInt
  width         Int?            @db.UnsignedSmallInt
  height        Int?            @db.UnsignedSmallInt
  duration_ms   Int?            @db.UnsignedInt
  blurhash      String?         @db.VarChar(100)
  alt_text      String?         @db.VarChar(255)
  uploaded_by   Int?
  created_at    DateTime        @default(now()) @db.DateTime(0)
  users         users?          @relation(fields: [uploaded_by], references: [id], onUpdate: NoAction, map: "FK_assets_users")
  product_media product_media[]

  @@index([uploaded_by], map: "FK_assets_users")
  @@index([mime_type], map: "IDX_assets_mime")
}

model product_content {
  id                                                                      Int                @id @default(autoincrement())
  product_id                                                              Int
  locale                                                                  String             @default("vi") @db.VarChar(10)
  seo_title                                                               String?            @db.VarChar(120)
  seo_description                                                         String?            @db.VarChar(320)
  seo_slug                                                                String?            @db.VarChar(200)
  og_data                                                                 Json?
  status                                                                  Int                @default(0) @db.TinyInt
  published_version_id                                                    Int?
  draft_version_id                                                        Int?
  published_at                                                            DateTime?          @db.DateTime(0)
  created_at                                                              DateTime           @default(now()) @db.DateTime(0)
  updated_at                                                              DateTime?          @db.DateTime(0)
  content_versions_content_versions_product_content_idToproduct_content   content_versions[] @relation("content_versions_product_content_idToproduct_content")
  content_versions_product_content_draft_version_idTocontent_versions     content_versions?  @relation("product_content_draft_version_idTocontent_versions", fields: [draft_version_id], references: [id], onUpdate: NoAction, map: "FK_content_draft_version")
  content_versions_product_content_published_version_idTocontent_versions content_versions?  @relation("product_content_published_version_idTocontent_versions", fields: [published_version_id], references: [id], onUpdate: NoAction, map: "FK_content_published_version")
  products                                                                products           @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_product_content_products")

  @@unique([product_id, locale], map: "UQ_product_content_locale")
  @@index([draft_version_id], map: "FK_content_draft_version")
  @@index([published_version_id], map: "FK_content_published_version")
}

model product_media {
  id               Int               @id @default(autoincrement())
  product_id       Int
  variant_id       Int?
  asset_id         Int
  media_role       String            @default("gallery") @db.VarChar(50)
  sort_order       Int               @default(0) @db.SmallInt
  alt_text         String?           @db.VarChar(255)
  media_assets     media_assets      @relation(fields: [asset_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_product_media_assets")
  products         products          @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_product_media_products")
  product_variants product_variants? @relation(fields: [variant_id], references: [id], onUpdate: NoAction, map: "FK_product_media_variants")

  @@index([asset_id], map: "FK_product_media_assets")
  @@index([product_id, media_role, sort_order], map: "IDX_product_media_product")
  @@index([variant_id], map: "IDX_product_media_variant")
}
