{
  "version": 2,
  "framework": null,
  "buildCommand": "npm run vercel-build",
  "functions": {
    "api/index.ts": {
      "maxDuration": 10,
      "includeFiles": [
        "prisma/**",
        "node_modules/.prisma/**",
        "node_modules/@prisma/**"
      ]
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
